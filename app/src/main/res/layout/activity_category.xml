<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/grey_gradient_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category Management"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#32CD32"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set Monthly Goals"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMinGoalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minimum Goal: R 1000"
        android:textColor="#FFFFFF"/>

    <SeekBar
        android:id="@+id/sbMinGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="5000"
        android:progress="1000"
        android:progressTint="#32CD32"
        android:thumbTint="#32CD32"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMaxGoalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Goal: R 5000"
        android:textColor="#FFFFFF"/>

    <SeekBar
        android:id="@+id/sbMaxGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10000"
        android:progress="5000"
        android:progressTint="#32CD32"
        android:thumbTint="#32CD32"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#32CD32"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etNewCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:autofillHints="none"
            android:hint="New Category Name"
            android:background="#222222"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:padding="12dp"/>

        <Button
            android:id="@+id/btnAddCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add"
            android:backgroundTint="#32CD32"
            android:textColor="#000000"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>