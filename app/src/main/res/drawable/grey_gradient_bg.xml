<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Layer: Black to Dark Grey -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#000000"
                android:centerColor="#333333"
                android:endColor="#1A1A1A"
                android:type="linear" />
        </shape>
    </item>
    <!-- Accent Layer: Lime Green Fade -->
    <item>
        <shape>
            <gradient
                android:angle="45"
                android:startColor="#00FFFFFF"
                android:centerColor="#4032CD32"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>